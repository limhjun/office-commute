# 환경 프로필 설정
# - dev: H2 개발용
# - mysql: 로컬 MySQL 검증용
# - prod: 운영용
SPRING_PROFILES_ACTIVE=mysql

# 데이터베이스 설정
DB_URL=jdbc:mysql://localhost:3306/office_commute?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=office_user
DB_PASSWORD=office_password

# 공공 API 설정 (실제 API 테스트시 필요)
PUBLIC_API_SERVICE_KEY=your-actual-api-service-key-here
PUBLIC_API_URL=http://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService/getRestDeInfo

# 서버 포트 (선택사항)
SERVER_PORT=8080
